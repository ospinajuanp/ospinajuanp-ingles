# Pexels API key(s) for verb hero images.
# Get a free key at https://www.pexels.com/api/ (200 req/hr, 20k/month).
# Leave both blank to fall back to Picsum + inline SVG.
# If VITE_PEXELS_API_KEY_2 is also set, the app uses the first one
# and automatically falls back to the second when the first returns
# 401 / 403 / 429 / 5xx or a network error. Set up multiple accounts
# to keep the app working through quota exhaustion.
VITE_PEXELS_API_KEY=
VITE_PEXELS_API_KEY_2=

MONGODB_URI=